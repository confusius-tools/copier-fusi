[project]
name = "{{ project_slug }}"
version = "0.1.0"
description = "{{ description }}"
readme = "README.md"
authors = [
    { name = "{{ author_name }}", email = "{{ author_email }}" },
]
{% set minor = python_version.split('.')[1] | int -%}
requires-python = ">={{ python_version }},<{{ python_version.split('.')[0] }}.{{ minor + 1 }}"
dependencies = [
    "confusius",
    "matplotlib>=3.0",
    "numpy>=2.0",
    "pandas>=2.0",
    "rich>=13.0",
    "scipy>=1.0",
    "seaborn>=0.13",
]

[build-system]
requires = ["uv_build>=0.9.5,<0.10.0"]
build-backend = "uv_build"

[dependency-groups]
dev = [
    "numpydoc>=1.9.0",
    "pre-commit>=4.0.0",
    "pytest>=8.0.0",
]

[tool.pytest.ini_options]
testpaths = ["tests"]
python_files = ["test_*.py"]
python_classes = ["Test*"]
python_functions = ["test_*"]

[tool.numpydoc_validation]
exclude = [
    '\.__init__$',
    '\._.*$',
]
checks = [
    "all",
    "GL01",
    "ES01",
    "SA01",
    "EX01",
]

[tool.uv.sources]
# confusius = { path = "../confusius", editable = true }
