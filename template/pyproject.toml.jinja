[project]
name = "{{ project_slug }}"
version = "0.1.0"
description = "{{ description }}"
readme = "README.md"
authors = [
    { name = "{{ author_name }}", email = "{{ author_email }}" },
]
{% set minor = python_version.split('.')[1] | int -%}
requires-python = ">={{ python_version }},<{{ python_version.split('.')[0] }}.{{ minor + 1 }}"
dependencies = [
    "confusius",
    "matplotlib>=3.0",
    "numpy>=2.0",
    "pandas>=2.0",
    "rich>=13.0",
    "scipy>=1.0",
    "seaborn>=0.13",
]

[build-system]
requires = ["uv-build>=0.9.5,<0.12.0"]
build-backend = "uv_build"

[dependency-groups]
dev = [
    "numpydoc>=1.9.0",
    "pre-commit>=4.0.0",
{%- if include_docs %}
    "mkdocstrings[python]>=1.0.3",
    "zensical>=0.0.40",
{%- endif %}
]

[tool.numpydoc_validation]
exclude = [
    '\.__init__$',
    '\._.*$',
]
checks = [
    "all",
    "GL01",
    "ES01",
    "SA01",
    "EX01",
]

